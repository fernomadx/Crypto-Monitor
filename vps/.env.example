# ============================================================
# Hetzner Cloud — BTCCURSOR — Kronos + bot Telegram dedicado
# Guia: vps/BTCCURSOR.md
# cp vps/.env.example vps/.env && nano vps/.env
# ============================================================

# Bot só do Kronos (crie em @BotFather — nome ex.: BTCCURSOR Kronos Bot)
KRONOS_TELEGRAM_BOT_TOKEN=your_kronos_bot_token_here
KRONOS_TELEGRAM_CHAT_ID=your_chat_id_here

# Não use o bot do crypto-monitor Railway aqui (evita misturar alertas).
# Se deixar KRONOS_* vazio, cai no TELEGRAM_* abaixo (não recomendado na VPS).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# SQLite da performance Kronos na VPS (separado do Railway)
DB_PATH=/opt/crypto-monitor/data/kronos_vps.db

# Caminho do clone Kronos
KRONOS_PATH=/opt/Kronos

# Modelo leve para CPU na VPS
KRONOS_MODEL=NeoQuasar/Kronos-mini
KRONOS_TOKENIZER=NeoQuasar/Kronos-Tokenizer-2k
KRONOS_MAX_CONTEXT=2048
KRONOS_DEVICE=cpu

# Mesmas moedas do monitor (ou só BTC)
TICKERS=BTC,ETH,SOL
KRONOS_TIMEFRAMES=1h,4h,1d

KRONOS_CHART_DIR=/opt/crypto-monitor/vps/charts
KRONOS_SAMPLE_COUNT=4
KRONOS_TEMPERATURE=0.65
KRONOS_BIAS_THRESHOLD_PCT=0.30

# Scorecard — simulação (ordens limite + taxas)
KRONOS_INITIAL_CAPITAL=1000
KRONOS_POSITION_USDC=100
KRONOS_LEVERAGE=10
KRONOS_SCORE_INTERVAL=4h
KRONOS_MIN_TF_AGREEMENT=2
KRONOS_FEE_MAKER_PCT=0.02
KRONOS_FEE_TAKER_PCT=0.05
KRONOS_LIMIT_ENTRY_BARS=6
KRONOS_LIMIT_ENTRY_OFFSET_PCT=0.15
KRONOS_BIAS_BARS=4
KRONOS_TARGET_BARS=8
KRONOS_MIN_TARGET_PCT=0.5
KRONOS_MIN_RR=2.0
KRONOS_MAX_STOP_PCT_4H=1.8
KRONOS_MAX_STOP_PCT=1.5

# --- QUANT (LLMQuant / QuantMind-style) — bot + watcher + hook Kronos ---
# Bot principal para /pesquisa (pode ser o mesmo do Railway monitor)
TELEGRAM_BOT_TOKEN=your_main_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

LLMQUANT_API_KEY=your_llmquant_api_key
ANTHROPIC_API_KEY=your_anthropic_key
CRYPTOPANIC_API_KEY=
NEWS_API_KEY=

QUANT_STATE_PATH=/data/quant_state.json
QUANT_IMPACT_THRESHOLD=0.65
QUANT_POLL_MINUTES=5
QUANT_KRONOS_VETO=1
QUANT_MAX_AGE_HOURS=4
QUANT_BOT_OFFSET=/data/quant_bot_offset.txt

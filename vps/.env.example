# ============================================================
# VPS BTCCURSOR — Kronos → Telegram (mesmo bot, alerta [KRONOS])
# cp vps/.env.example vps/.env && nano vps/.env
# ============================================================

# Mesmas credenciais do crypto-monitor / Railway
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=7696151400

# Caminho do clone Kronos (ajuste se necessário)
KRONOS_PATH=/opt/Kronos

# Modelo leve para CPU na VPS (recomendado)
KRONOS_MODEL=NeoQuasar/Kronos-mini
KRONOS_TOKENIZER=NeoQuasar/Kronos-Tokenizer-2k
KRONOS_MAX_CONTEXT=2048
KRONOS_DEVICE=cpu

# Mercado — candles MEXC (público, sem API key)
KRONOS_TICKERS=BTCUSDT,ETHUSDT,SOLUSDT

# Timeframes do relatório (texto + 1 gráfico cada): 1h, 4h, 1d
KRONOS_TIMEFRAMES=1h,4h,1d

# Pasta dos PNG enviados ao Telegram
KRONOS_CHART_DIR=/opt/crypto-monitor/vps/charts

# Amostragem (mais sample_count = mais lento, mais estável)
KRONOS_SAMPLE_COUNT=4
KRONOS_TEMPERATURE=1.0
KRONOS_TOP_P=0.9

# Scorecard — simulação de PnL (ordens limite + taxas MEXC spot)
KRONOS_INITIAL_CAPITAL=1000
KRONOS_POSITION_USDC=100
KRONOS_LEVERAGE=10
KRONOS_SCORE_INTERVAL=4h
KRONOS_MIN_TF_AGREEMENT=2
KRONOS_FEE_MAKER_PCT=0.02
KRONOS_FEE_TAKER_PCT=0.05
KRONOS_LIMIT_ENTRY_BARS=4
KRONOS_BIAS_BARS=4
KRONOS_TARGET_BARS=8
KRONOS_MIN_TARGET_PCT=0.35
KRONOS_MIN_RR=1.5
KRONOS_MAX_STOP_PCT=1.2

# Relatório diário Telegram: crontab 15:00 UTC = 12:00 BRT (UTC-3)
# Para 12:00 UTC, altere crontab para: 0 12 * * *

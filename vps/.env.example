# ============================================================
# VPS BTCCURSOR — Kronos → Telegram (mesmo bot, alerta [KRONOS])
# cp vps/.env.example vps/.env && nano vps/.env
# ============================================================

# Mesmas credenciais do crypto-monitor / Railway
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=7696151400

# Caminho do clone Kronos (ajuste se necessário)
KRONOS_PATH=/opt/Kronos

# Modelo leve para CPU na VPS (recomendado)
KRONOS_MODEL=NeoQuasar/Kronos-mini
KRONOS_TOKENIZER=NeoQuasar/Kronos-Tokenizer-2k
KRONOS_MAX_CONTEXT=2048
KRONOS_DEVICE=cpu

# Mercado — candles MEXC (público, sem API key)
KRONOS_TICKERS=BTCUSDT,ETHUSDT,SOLUSDT
KRONOS_INTERVAL=15m
KRONOS_LOOKBACK=400
KRONOS_PRED_LEN=12

# Amostragem (mais sample_count = mais lento, mais estável)
KRONOS_SAMPLE_COUNT=4
KRONOS_TEMPERATURE=1.0
KRONOS_TOP_P=0.9

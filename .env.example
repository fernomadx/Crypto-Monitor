# ============================================================
# crypto-monitor — variáveis de ambiente
# NUNCA commite este arquivo com valores reais.
# Cole os valores reais no painel Railway > Variables.
# ============================================================

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# MEXC (read-only, sem permissão de trade/withdraw)
MEXC_API_KEY=your_mexc_api_key_here
MEXC_API_SECRET=your_mexc_api_secret_here
# HTTP candles (Kronos + futures BTCCURSOR): timeout/retry
# MEXC_HTTP_TIMEOUT_SEC=45
# MEXC_HTTP_RETRIES=4
# MEXC_CONTRACT_BASE=https://contract.mexc.com
# Alerta Telegram "Saldo MEXC" — false/0/off para desativar (Kronos ainda usa candles MEXC)
MEXC_BALANCE_ALERTS=true

# Anthropic (Claude Haiku — camada 2 de sentimento + orchestrator)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# News sources
CRYPTOPANIC_API_KEY=your_cryptopanic_key_here
NEWS_API_KEY=your_newsapi_key_here

# Configurações (já preenchidas com defaults acordados)
HYPERLIQUID_ADDRESS=0xA81aac9FbB0659F4e8d33a55cc8bACFF0Ac104b2
TICKERS=BTC,ETH,SOL
FUNDING_THRESHOLD=0.0005

# Path do banco SQLite (Railway monta o volume em /data)
DB_PATH=/data/crypto_monitor.db

# QUANT (LLMQuant + alertas [QUANT] — mesmo bot Telegram)
LLMQUANT_API_KEY=your_llmquant_api_key
QUANT_KRONOS_MODE=warn
QUANT_STATE_PATH=/data/quant_state.json
QUANT_IMPACT_THRESHOLD=0.70
# Digest notícias a cada fechamento candle 1H (:01 UTC)
QUANT_HOURLY_NEWS=true
QUANT_HOURLY_LOOKBACK_MIN=65
QUANT_HOURLY_MAX_HEADLINES=6
QUANT_HOURLY_MIN_RELEVANCE=0.45
QUANT_DISPLAY_TZ=Europe/Dublin
# Alertas imediatos de notícia forte (≥ threshold) — cron 5 min
QUANT_IMPACT_ALERTS=true
